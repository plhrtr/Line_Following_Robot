{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "STM32 Native GDB (st-util)",
      "type": "gdb",
      "request": "attach",
      "executable": "${workspaceFolder}/build/ArmuroL432.elf",
      "target": "localhost:4242",
      "remote": true,
      "postRemoteConnectCommands": [
        "monitor reset halt",
        "load"
      ]
    }
  ]
}
